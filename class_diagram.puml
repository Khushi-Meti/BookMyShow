@startuml BookMyShow Class Diagram

title BookMyShow - Online Movie Ticket Booking System

package "Controllers" {
    class BookingController {
        + bookSeats(BookingRequestDTO): ResponseEntity<?>
        + getBookingById(Long): ResponseEntity<BookingDTO>
        + getBookingsByUserId(Long): ResponseEntity<List<BookingDTO>>
        + getBookingsByShowId(Long): ResponseEntity<List<BookingDTO>>
    }

    class MovieController {
        + createMovie(MovieDTO): ResponseEntity<MovieDTO>
        + getMovieById(Long): ResponseEntity<MovieDTO>
        + getAllMovies(): ResponseEntity<List<MovieDTO>>
        + getMoviesByLanguage(String): ResponseEntity<List<MovieDTO>>
        + updateMovie(Long, MovieDTO): ResponseEntity<MovieDTO>
        + deleteMovie(Long): ResponseEntity<Void>
    }

    class TheatreController {
        + createTheatre(TheatreDTO): ResponseEntity<TheatreDTO>
        + getTheatreById(Long): ResponseEntity<TheatreDTO>
        + getAllTheatres(): ResponseEntity<List<TheatreDTO>>
        + updateTheatre(Long, TheatreDTO): ResponseEntity<TheatreDTO>
        + deleteTheatre(Long): ResponseEntity<Void>
    }

    class ShowController {
        + createShow(ShowDTO): ResponseEntity<ShowDTO>
        + getShowById(Long): ResponseEntity<ShowDTO>
        + getShowsByMovieId(Long): ResponseEntity<List<ShowDTO>>
        + getShowsByTheatreId(Long): ResponseEntity<List<ShowDTO>>
        + updateShow(Long, ShowDTO): ResponseEntity<ShowDTO>
        + deleteShow(Long): ResponseEntity<Void>
    }

    class UserController {
        + createUser(UserDTO): ResponseEntity<UserDTO>
        + getUserById(Long): ResponseEntity<UserDTO>
        + getAllUsers(): ResponseEntity<List<UserDTO>>
        + updateUser(Long, UserDTO): ResponseEntity<UserDTO>
        + deleteUser(Long): ResponseEntity<Void>
    }

    class SeatController {
        + getSeatsByScreenAndShow(Long, Long, Long?): ResponseEntity<List<SeatDTO>>
        + lockSeat(SeatLockRequest): ResponseEntity<?>
        + unlockSeat(SeatLockRequest): ResponseEntity<?>
    }
}

package "Services" {
    class BookingService {
        + bookSeats(BookingRequestDTO): BookingConfirmationDTO
        - createPendingBooking(Long, Long): Booking
        - validShowExists(Long): Show
        - validateSeatsForShow(Long, List<Long>): List<Seat>
        - checkAndThrowIfAnyBookedSeat(List<ShowSeat>): void
        - simulatePaymentProcessing(Long, int): PaymentResult
        - markSeatsAsBooked(Booking, Show, List<Seat>, List<ShowSeat>, Long): List<String>
        - updateBookingStatus(Long, BookingStatus): void
        - buildBookingConfirmation(Booking, Show, List<String>): BookingConfirmationDTO
    }

    class MovieService {
        + createMovie(MovieDTO): MovieDTO
        + getMovieById(Long): MovieDTO
        + getAllMovies(): List<MovieDTO>
        + getMoviesByLanguage(String): List<MovieDTO>
        + updateMovie(Long, MovieDTO): MovieDTO
        + deleteMovie(Long): void
        - convertEntityToDTO(Movie): MovieDTO
        - convertDTOToEntity(MovieDTO): Movie
    }

    class TheatreService {
        + createTheatre(TheatreDTO): TheatreDTO
        + getTheatreById(Long): TheatreDTO
        + getAllTheatres(): List<TheatreDTO>
        + updateTheatre(Long, TheatreDTO): TheatreDTO
        + deleteTheatre(Long): void
        - convertEntityToDTO(Theatre): TheatreDTO
        - convertDTOToEntity(TheatreDTO): Theatre
    }

    class ShowService {
        + createShow(ShowDTO): ShowDTO
        + getShowById(Long): ShowDTO
        + getShowsByMovieId(Long): List<ShowDTO>
        + getShowsByTheatreId(Long): List<ShowDTO>
        + updateShow(Long, ShowDTO): ShowDTO
        + deleteShow(Long): void
        - convertEntityToDTO(Show): ShowDTO
        - convertDTOToEntity(ShowDTO): Show
    }

    class UserService {
        + createUser(UserDTO): UserDTO
        + getUserById(Long): UserDTO
        + getAllUsers(): List<UserDTO>
        + updateUser(Long, UserDTO): UserDTO
        + deleteUser(Long): void
        - convertEntityToDTO(User): UserDTO
        - convertDTOToEntity(UserDTO): User
    }

    class SeatLockService {
        + lockSeats(Long, List<Long>, Long): void
        + unlockSeats(Long, List<Long>, Long): void
        + unlockAllSeatsForUser(Long, Long): void
        + releaseExpiredLocks(): void
    }

    class SeatLockCleanupScheduler {
        + releaseExpiredLocks(): void
    }
}

package "Repositories" {
    interface JpaRepository<T, ID> {
        + save(T): T
        + findById(ID): Optional<T>
        + findAll(): List<T>
        + deleteById(ID): void
        + delete(T): void
    }

    class BookingRepository {
        + findByUserId(Long): List<Booking>
        + findByShowId(Long): List<Booking>
    }

    class MovieRepository {
        + findByName(String): Optional<Movie>
        + findByLanguage(String): List<Movie>
    }

    class TheatreRepository {
        + findByLocation(String): List<Theatre>
    }

    class ScreenRepository {
        + findByTheatreId(Long): List<Screen>
    }

    class SeatRepository {
        + findByScreenId(Long): List<Seat>
    }

    class ShowRepository {
        + findByMovieId(Long): List<Show>
        + findByTheatreId(Long): List<Show>
        + findByScreenId(Long): List<Show>
    }

    class ShowSeatRepository {
        + findByShowId(Long): List<ShowSeat>
        + findBySeatId(Long): List<ShowSeat>
        + findByBookingId(Long): List<ShowSeat>
        + findByShowIdAndSeatIdsWithLock(Long, List<Long>): List<ShowSeat>
        + findByShowIdAndSeatIdWithLock(Long, Long): Optional<ShowSeat>
        + findExpiredLocks(LocalDateTime): List<ShowSeat>
        + findLockedByUserAndShow(Long, Long): List<ShowSeat>
    }

    class UserRepository {
        + findByEmail(String): Optional<User>
    }
}

package "Models" {
    class Movie {
        - id: Long
        - name: String
        - duration: Integer
        - language: String
        - createdAt: LocalDateTime
        - updatedAt: LocalDateTime
        - shows: List<Show>
    }

    class Theatre {
        - id: Long
        - name: String
        - location: String
        - createdAt: LocalDateTime
        - updatedAt: LocalDateTime
        - screens: List<Screen>
    }

    class Screen {
        - id: Long
        - name: String
        - totalSeats: Integer
        - createdAt: LocalDateTime
        - updatedAt: LocalDateTime
        - theatre: Theatre
        - seats: List<Seat>
        - shows: List<Show>
    }

    class Seat {
        - id: Long
        - seatNumber: String
        - seatType: SeatType
        - createdAt: LocalDateTime
        - updatedAt: LocalDateTime
        - screen: Screen
        - showSeats: List<ShowSeat>
    }

    class Show {
        - id: Long
        - startTime: LocalDateTime
        - endTime: LocalDateTime
        - createdAt: LocalDateTime
        - updatedAt: LocalDateTime
        - movie: Movie
        - screen: Screen
        - showSeats: List<ShowSeat>
        - bookings: List<Booking>
    }

    class ShowSeat {
        - id: Long
        - status: SeatStatus
        - isBooked: Boolean
        - lockedAt: LocalDateTime
        - lockedByUserId: Long
        - createdAt: LocalDateTime
        - updatedAt: LocalDateTime
        - show: Show
        - seat: Seat
        - booking: Booking
    }

    class Booking {
        - id: Long
        - userId: Long
        - bookingTime: LocalDateTime
        - status: BookingStatus
        - createdAt: LocalDateTime
        - updatedAt: LocalDateTime
        - show: Show
        - bookedSeats: List<ShowSeat>
    }

    class User {
        - id: Long
        - name: String
        - email: String
        - createdAt: LocalDateTime
        - updatedAt: LocalDateTime
    }

    enum SeatType {
        STANDARD
        PREMIUM
        RECLINER
    }

    enum SeatStatus {
        AVAILABLE
        LOCKED
        BOOKED
    }

    enum BookingStatus {
        PENDING
        CONFIRMED
        FAILED
    }
}

package "DTOs" {
    class MovieDTO {
        + id: Long
        + name: String
        + duration: Integer
        + language: String
    }

    class TheatreDTO {
        + id: Long
        + name: String
        + location: String
    }

    class ScreenDTO {
        + id: Long
        + name: String
        + totalSeats: Integer
    }

    class SeatDTO {
        + id: Long
        + seatNumber: String
        + seatType: String
        + status: String
    }

    class ShowDTO {
        + id: Long
        + startTime: LocalDateTime
        + endTime: LocalDateTime
        + movieName: String
        + theatreName: String
        + screenName: String
    }

    class UserDTO {
        + id: Long
        + name: String
        + email: String
    }

    class BookingRequestDTO {
        + userId: Long
        + showId: Long
        + seatIds: List<Long>
    }

    class BookingConfirmationDTO {
        + bookingId: Long
        + movieName: String
        + theatreName: String
        + screenName: String
        + showTime: LocalDateTime
        + seats: List<String>
        + totalAmount: Double
    }

    class BookingDTO {
        + id: Long
        + userId: Long
        + showId: Long
        + bookingTime: LocalDateTime
        + status: String
        + movieName: String
        + theatreName: String
        + seats: List<String>
        + totalAmount: Double
    }

    class SeatLockRequest {
        + showId: Long
        + seatId: Long
        + userId: Long
    }
}

package "Init" {
    class DataInitializer {
        + run(String[]): void
    }
}

package "Main" {
    class BookMyShowApplication {
        + main(String[]): void
    }
}

' Relationships
' Controllers to Services
BookingController ..> BookingService : uses
MovieController ..> MovieService : uses
TheatreController ..> TheatreService : uses
ShowController ..> ShowService : uses
UserController ..> UserService : uses
SeatController ..> SeatLockService : uses

' Services to Repositories
BookingService ..> BookingRepository : uses
BookingService ..> ShowRepository : uses
BookingService ..> SeatRepository : uses
BookingService ..> ShowSeatRepository : uses
MovieService ..> MovieRepository : uses
TheatreService ..> TheatreRepository : uses
ShowService ..> ShowRepository : uses
UserService ..> UserRepository : uses
SeatLockService ..> ShowSeatRepository : uses
SeatLockCleanupScheduler ..> SeatLockService : uses

' Repositories extend JpaRepository
BookingRepository ..|> JpaRepository : extends
MovieRepository ..|> JpaRepository : extends
TheatreRepository ..|> JpaRepository : extends
ScreenRepository ..|> JpaRepository : extends
SeatRepository ..|> JpaRepository : extends
ShowRepository ..|> JpaRepository : extends
ShowSeatRepository ..|> JpaRepository : extends
UserRepository ..|> JpaRepository : extends

' Entity Relationships (JPA)
Movie "1" --> "0..*" Show : has
Theatre "1" --> "0..*" Screen : has
Screen "1" --> "0..*" Seat : has
Screen "1" --> "0..*" Show : has
Show "1" --> "0..*" ShowSeat : has
Show "1" --> "0..*" Booking : has
Seat "1" --> "0..*" ShowSeat : has
Booking "1" --> "0..*" ShowSeat : bookedSeats
ShowSeat "1" --> "1" Booking : booking

' Service to DTO conversions
BookingService ..> BookingDTO : converts
BookingService ..> BookingConfirmationDTO : returns
MovieService ..> MovieDTO : converts
TheatreService ..> TheatreDTO : converts
ShowService ..> ShowDTO : converts
UserService ..> UserDTO : converts

' DataInitializer uses all repositories
DataInitializer ..> BookingRepository : uses
DataInitializer ..> MovieRepository : uses
DataInitializer ..> TheatreRepository : uses
DataInitializer ..> ScreenRepository : uses
DataInitializer ..> SeatRepository : uses
DataInitializer ..> ShowRepository : uses
DataInitializer ..> ShowSeatRepository : uses
DataInitializer ..> UserRepository : uses

' Application initializes data
BookMyShowApplication --> DataInitializer : initializes

' Pessimistic Locking Highlight
note right of ShowSeatRepository : Pessimistic Write Locks\nprevent race conditions\nduring seat booking
note right of SeatLockService : Manages seat locking\nwith 5-minute expiry
note right of SeatLockCleanupScheduler : Scheduled cleanup\nof expired locks

@enduml